{
	"schemaVersion": 1,
	"id": "couplesmod",
	"version": "${version}",
	"name": "CouplesMod",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/couplesmod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.linceros.couplesmod.CouplesMod"
		],
		"client": [
			"com.linceros.couplesmod.client.CouplesModClient"
		],
		"fabric-datagen": [
			"com.linceros.couplesmod.datagen.CouplesDataGenerator"
		]
	},
	"mixins": [
		"couplesmod.mixins.json",
		{
			"config": "couplesmod.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	}
}